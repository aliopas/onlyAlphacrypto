# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, or local)
DATABASE_URL=postgresql://user:password@localhost:5432/onlyalpha

# ─── Redis ────────────────────────────────────────────────────────────────────
# Optional — rate limiting + caching (remove to disable)
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_string_in_production
JWT_EXPIRES_IN=7d

# ─── OpenRouter ───────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
SEO_MODEL=openai/gpt-5-nano

# ─── BINNS (AI News Verification) ──────────────────────────────────────────
BINNS_SECRET_KEY=
BINNS_API_KEY=

# ─── GLM (Zhipu AI - Direct API) ────────────────────────────────────────────────
# Used for deep analysis (cheaper at scale than GLM-5)
GLM_API_KEY=your_glm_api_key_here
GLM_MODEL=glm-4-plus
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ─── Binance (optional for authenticated requests) ────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET=

# ─── Moralis (Web3 wallet tracking) ──────────────────────────────────────────
MORALIS_API_KEY=

# ─── Alternative.me (Fear & Greed) ───────────────────────────────────────────
ALTERNATIVE_ME_URL=https://api.alternative.me/fng/

# ─── Next.js Cache Revalidation (optional) ────────────────────────────────────
NEXTJS_REVALIDATE_SECRET=
NEXTJS_BASE_URL=http://localhost:3000
