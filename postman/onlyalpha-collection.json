    {
      "name": "Chat",
      "item": [
        {
          "name": "Stream (General)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"coin\": \"BTC\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"What is the current price of Bitcoin?\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/chat/stream",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "stream"]
            }
          },
          "description": "General AI chat stream. Authentication is optional — unauthenticated users get guest limits."
        },
        {
          "name": "Stream (Context Mode)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"coin\": \"BTC\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Explain the recent news about Bitcoin\"\n    }\n  ],\n  \"mode\": \"context\",\n  \"articleId\": 123,\n  \"articleType\": \"WIRE\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/chat/stream/context",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "stream", "context"]
            }
          },
          "description": "Context-aware AI chat stream. Requires authentication. Grounds responses in a specific article."
        },
        {
          "name": "Accept Disclaimer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/chat/disclaimer-accept",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "disclaimer-accept"]
            }
          },
          "description": "Accept the AI disclaimer. Must be accepted before using chat features. Requires authentication."
        },
        {
          "name": "Disclaimer Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "description": "Optional — returns false if unauthenticated" }
            ],
            "url": {
              "raw": "{{base_url}}/api/chat/disclaimer-status",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "disclaimer-status"]
            }
          },
          "description": "Check if the current user has accepted the AI disclaimer."
        },
        {
          "name": "Article Context",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "description": "Optional — include for personalized context" }
            ],
            "url": {
              "raw": "{{base_url}}/api/chat/context/:articleId/:articleType",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "context", ":articleId", ":articleType"],
              "variable": [
                { "key": "articleId", "value": "123", "description": "Article ID" },
                { "key": "articleType", "value": "WIRE", "description": "Article type: WIRE or MASTER" }
              ]
            }
          },
          "description": "Fetch the context payload for grounding an AI chat conversation in a specific article."
        }
      ]
