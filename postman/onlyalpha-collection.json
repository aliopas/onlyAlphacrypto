{
  "info": {
    "name": "OnlyAlpha API",
    "description": "Complete API collection for the OnlyAlpha crypto intelligence platform. All endpoints documented with correct HTTP methods, headers, and parameters.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/health",
              "host": ["{{base_url}}"],
              "path": ["api", "health"]
            }
          },
          "description": "Comprehensive system health check. Returns status of Database, pgvector, Redis, and OpenRouter API connectivity with latency measurements."
        }
      ]
    },
    {
      "name": "Market",
      "item": [
        {
          "name": "Wire Feed",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/market/wire?coin=&limit=&offset=",
              "host": ["{{base_url}}"],
              "path": ["api", "market", "wire"],
              "query": [
                { "key": "coin", "value": "", "description": "Filter by coin symbol (e.g. BTC)" },
                { "key": "limit", "value": "", "description": "Number of items per page" },
                { "key": "offset", "value": "", "description": "Pagination offset" }
              ]
            }
          },
          "description": "Paginated news wire feed with optional coin filter and cursor-based pagination."
        },
        {
          "name": "Wire Article by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/market/wire/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "market", "wire", ":id"],
              "variable": [
                { "key": "id", "value": "1", "description": "Article ID" }
              ]
            }
          },
          "description": "Fetch a single wire article by its unique ID."
        },
        {
          "name": "Radar Signals",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/market/radar?limit=&offset=",
              "host": ["{{base_url}}"],
              "path": ["api", "market", "radar"],
              "query": [
                { "key": "limit", "value": "", "description": "Number of items per page" },
                { "key": "offset", "value": "", "description": "Pagination offset" }
              ]
            }
          },
          "description": "Paginated radar signals showing coins with high conviction scores and recent activity."
        },
        {
          "name": "Coin Insight",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/market/insight/:symbol",
              "host": ["{{base_url}}"],
              "path": ["api", "market", "insight", ":symbol"],
              "variable": [
                { "key": "symbol", "value": "BTC", "description": "Coin symbol (e.g. BTC, ETH)" }
              ]
            }
          },
          "description": "Deep AI-generated insight for a specific coin symbol including sentiment, price targets, and key facts."
        },
        {
          "name": "Master Article",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "description": "Optional — include for personalized content" }
            ],
            "url": {
              "raw": "{{base_url}}/api/market/master/:symbol",
              "host": ["{{base_url}}"],
              "path": ["api", "market", "master", ":symbol"],
              "variable": [
                { "key": "symbol", "value": "BTC", "description": "Coin symbol" }
              ]
            }
          },
          "description": "Living master article for a coin — continuously updated with latest analysis, timeline, and conviction score."
        },
        {
          "name": "Timeline Updates",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "description": "Optional — include for personalized content" }
            ],
            "url": {
              "raw": "{{base_url}}/api/market/timeline/:symbol?offset=&limit=",
              "host": ["{{base_url}}"],
              "path": ["api", "market", "timeline", ":symbol"],
              "query": [
                { "key": "offset", "value": "", "description": "Pagination offset" },
                { "key": "limit", "value": "", "description": "Number of items per page" }
              ],
              "variable": [
                { "key": "symbol", "value": "BTC", "description": "Coin symbol" }
              ]
            }
          },
          "description": "Paginated timeline of events and updates for a specific coin's master article."
        },
        {
          "name": "Top Movers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/market/movers",
              "host": ["{{base_url}}"],
              "path": ["api", "market", "movers"]
            }
          },
          "description": "Returns the top gaining and losing coins based on recent price movement."
        },
        {
          "name": "Market Mood",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/market/mood",
              "host": ["{{base_url}}"],
              "path": ["api", "market", "mood"]
            }
          },
          "description": "Aggregated market sentiment and mood indicator derived from Fear & Greed index and recent news analysis."
        },
        {
          "name": "Alpha Focus",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/market/alpha-focus",
              "host": ["{{base_url}}"],
              "path": ["api", "market", "alpha-focus"]
            }
          },
          "description": "Curated list of high-conviction coins currently in the alpha focus zone."
        },
        {
          "name": "Asset Count",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/market/asset-count",
              "host": ["{{base_url}}"],
              "path": ["api", "market", "asset-count"]
            }
          },
          "description": "Returns the total number of tracked assets in the system."
        },
        {
          "name": "Force Seed",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/market/force-seed",
              "host": ["{{base_url}}"],
              "path": ["api", "market", "force-seed"]
            }
          },
          "description": "Admin-only endpoint to force-trigger the master article seeding cron job. Requires authentication."
        }
      ]
    },
    {
      "name": "Airdrop",
      "item": [
        {
          "name": "Projects",
          "request": {
            "method": "GET",
